const ENC_NAILAMMO=ENC_776*1.25;
const ENC_NAILAMMO_LOADED=ENC_776*1.09;

class HDB_VIRNAIL : HDBulletActor
{
	Default
	{
		PushFactor 0.1;
		gravity HDCONST_GRAVITY*0.7;
		Mass 155;
		Speed 120;
		Accuracy 330;
		Stamina 950;
		WoundHealth 20;
		HDBulletActor.Hardness 5;
	}
	
override void HitGeometry(line hitline, sector hitsector, int hitside,
    int hitpart, vector3 vu, double lastdist)
{
    Super.HitGeometry(hitline, hitsector, hitside, hitpart, vu, lastdist);

    Actor drop;
    Name nailType;

    setorigin(pos - vu, false);

    nailType = (random(0, 99) < 34) ? 'BentVirNail' : 'LooseVirNail';

    if (hitline)
    {
        drop = Spawn(nailType, pos, ALLOW_REPLACE);
    }
    else if (hitsector)
    {
        switch (hitpart)
        {
            case SECPART_Ceiling:
            case SECPART_Floor:
                drop = Spawn(nailType, pos, ALLOW_REPLACE);
                break;
        }
    }

    if (drop){drop.angle = angle;}

    BulletDie();
}
	
	states{
	spawn:
		VNAL A -1;
		stop;
	}
}

class VirNailAmmo : HDRoundAmmo
{
	Default
	{
		+INVENTORY.IGNORESKILL
		+CANNOTPUSH
//		+FORCEXYBILLBOARD
		+ROLLSPRITE
		+ROLLCENTER
		+HDPICKUP.MULTIPICKUP
		XScale 0.25;
		YScale 0.25;
		Tag "$TAG_NAIL";
		Inventory.icon "VNA2B0";
		Inventory.PickupMessage "$PICKUP_NAIL";
		hdpickup.bulk ENC_NAILAMMO;
		HDPickup.RefId "vnl";
//		HDPickup.Bulk EncRound;
	}
	
	override void SplitPickup()
	{
		SplitPickupBoxableRound(10, 70, "VirNailBox", "VNA2A0", "VNALA0");
	}
	
	States
	{
		Spawn:
			VNAL A -1;
			VNA2 A -1;
			stop;
	}
}

