class LooseVirNail:HDSpent7mm{
	override void PostBeginPlay()
	{
		Super.PostBeginPlay();

		double spread = random(-3000,3000) / 100.0;
		double dir = angle + spread;
		double speed = random(100,400) / 100.0;

		vel.x += cos(dir) * speed;
		vel.y += sin(dir) * speed;
		vel.z += random(50,200) / 100.0;
	}
	default{
//		gravity 0;
		scale 0.25;
//		bouncefactor 0.6;
		hdupk.pickuptype "VirNailAmmo";
		hdupk.pickupmessage "$PICKUP_NAIL";
	}
		states{
	spawn:
		VNAL A 2{
//			if(bseesdaggers)angle-=45;else angle+=45;
			if(pos.z-floorz<2&&abs(vel.z)<2.)setstatelabel("death");
		}wait;
	death:
		VNAL A -1{
			if(hdmath.deathmatchclutter())A_SetTics(140);
			bmissile=false;
			vel.xy+=(pos.xy-lastpos.xy)*max(abs(vel.z),abs(lastpos.z-pos.z),1.);
			if(vel.xy==(0,0)){
				double aaa=angle-90;
				vel.x+=cos(aaa);
				vel.y+=sin(aaa);
			}else{
				A_FaceMovementDirection();
				angle+=90;
			}
			let gdb=getdefaultbytype(pickuptype);
			A_SetSize(gdb.radius,gdb.height);
			return;
		}stop;
	}
}

